# Remote host the (large) résumé videos stream from in the single-file build.
# The single-file attachment (<name>_resume_offline_<MM.YYYY>.html) inlines everything EXCEPT videos —
# each video src is rewritten to ${VITE_MEDIA_BASE_URL}/assets/video/<file> so they play
# when online and fall back to the inlined poster still when offline.
#
# Leave empty here: the single build already defaults to https://codegor.github.io/resume,
# and the multifile/hosting build serves videos locally from assets/video/*. Set it only
# to override the host (e.g. a different CDN).
VITE_MEDIA_BASE_URL=

# The single build's fallback host when VITE_MEDIA_BASE_URL is empty. Defaults to
# https://codegor.github.io/resume (baked into vite.config.ts). Override to retarget the
# default media host without forcing it onto the multifile build via VITE_MEDIA_BASE_URL.
VITE_DEFAULT_MEDIA_BASE_URL=

# The "live résumé" URL — the globe icon in the top bar, the "Resume" item in the
# mobile contacts menu, the print contacts block, and the Markdown (.md) export all
# link to it. Leave empty to use config.json's `resumeUrl` (the GitHub Pages prod URL,
# https://codegor.github.io/resume/). Set it to point the live link at a dev/staging
# host instead, e.g. http://resume.local.
VITE_RESUME_URL=
