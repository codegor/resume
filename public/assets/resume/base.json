  "how_i_work": {
    "label": "Principle",
    "title": "Bug-free by design",
    "lead": "My base rule isn't *“no bugs”* — it's **correctness engineered in**, so whole classes of bugs can't exist in the first place.",
    "points": [
      {
        "title": "Architecture first",
        "desc": "Every detail planned before a line of code is written."
      },
      {
        "title": "Typed contracts",
        "desc": "SOLID, typed APIs and schema-tested boundaries."
      },
      {
        "title": "Bug-proof coding rules",
        "desc": "A personal collection of practices and principles that catch mistakes at the coding step — as the code is written."
      },
      {
        "title": "QA gates in PR",
        "desc": "Nothing merges until checks pass in CI."
      }
    ]
