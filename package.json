{
  "name": "resume",
  "version": "2.0.0",
  "description": "Filterable living résumé of Egor Berezovsky — Vue 3 + Vite + TypeScript.",
  "author": "Egor Berezovsky <codeegor@gmail.com>",
  "license": "LicenseRef-Proprietary",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build:multi": "vite build",
    "build:single": "vite build --mode single && node scripts/finalize-single.mjs",
    "build": "vue-tsc --noEmit && yarn build:multi && yarn build:single",
    "optimize:images": "node scripts/optimize-images.mjs",
    "gen:variants": "node scripts/gen-image-variants.mjs",
    "watch": "vite build --watch",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint \"**/*.{vue,scss}\"",
    "lint:style:fix": "stylelint \"**/*.{vue,scss}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "yarn type-check && yarn lint && yarn lint:style && yarn format:check",
    "test": "cross-env NODE_PATH=node_modules playwright test",
    "test:ui": "cross-env NODE_PATH=node_modules playwright test --ui",
    "test:headed": "cross-env NODE_PATH=node_modules playwright test --headed",
    "test:report": "playwright show-report",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "i18n:sync": "node scripts/i18n-extract-keys.mjs"
  },
  "dependencies": {
    "vue": "3.5.35"
  },
  "resolutions": {
    "@vue/shared": "3.5.35",
    "@vue/compiler-core": "3.5.35",
    "@vue/compiler-dom": "3.5.35",
    "@vue/compiler-sfc": "3.5.35",
    "@vue/compiler-ssr": "3.5.35",
    "@vue/reactivity": "3.5.35",
    "@vue/runtime-core": "3.5.35",
    "@vue/runtime-dom": "3.5.35",
    "@vue/server-renderer": "3.5.35"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "postcss-html": "^1.8.0",
    "prettier": "^3.4.2",
    "sass": "^1.83.0",
    "sharp": "^0.33.5",
    "stylelint": "^16.12.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "terser": "^5.37.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-compression2": "^1.3.3",
    "vite-plugin-singlefile": "^2.1.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.1.10"
  },
  "packageManager": "yarn@1.22.22"
}
